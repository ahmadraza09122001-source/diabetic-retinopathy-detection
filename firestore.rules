rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write only their own data
    match /scans/{scanId} {
      // Owner can always read/write their own scans. A user whose OWN profile
      // has role "doctor" can additionally read (not write/delete) any scan -
      // needed so the Patient Directory can show each patient's latest result.
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'doctor'
      );
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    match /analytics/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /profiles/{userId} {
      // A user can always read/write their own profile. A user whose OWN
      // profile has role "doctor" can additionally read everyone else's
      // profile (needed for the Patient Directory) - writes stay restricted
      // to each user's own document regardless of role.
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'doctor'
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
